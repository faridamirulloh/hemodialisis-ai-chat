    "antd": "^5.27.5",
    "framer-motion": "^12.23.24",
    "isbot": "^5.1.31",
    "mobx-react-lite": "^4.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.9.4",
    "sass": "^1.93.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@eslint/json": "^0.12.0",
    "@react-router/dev": "^7.9.4",
    "@types/node": "^20.19.21",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.37.0",
