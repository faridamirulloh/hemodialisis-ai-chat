generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  name         String
  data         Json?
  createdAt    DateTime      @default(now()) @map("created_at")
  chatSessions ChatSession[] @relation("chat_sessions")
  records      Record[]

  @@map("users")
}

model ChatSession {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  title         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at")
  chatHistories ChatHistory[] @relation("chat_histories")
  user          User          @relation("chat_sessions", fields: [userId], references: [id])

  @@index([userId])
  @@map("chat_sessions")
}

model ChatHistory {
  sessionId   String      @map("session_id")
  message     Json
  createdAt   DateTime    @default(now()) @map("created_at")
  id          Int         @id @default(autoincrement())
  chatSession ChatSession @relation("chat_histories", fields: [sessionId], references: [id])

  @@index([sessionId])
  @@map("chat_histories")
}

model Record {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  date             DateTime @default(now())
  symptoms         Json     @default("[]")
  dialysisSchedule Json?    @map("dialysis_schedule")
  labResults       Json?    @map("lab_results")
  bloodPressure    Json?    @map("blood_pressure")
  weight           Float?
  height           Float?
  fluidIntake      Float?   @map("fluid_intake")
  dietNotes        String?  @map("diet_notes")
  medications      Json?
  note             String?
  mood             String?
  category         String   @default("general")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")
  user             User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("records")
}

model document_metadata {
  id         String    @id
  title      String?
  url        String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  schema     String?
}

model documents {
  id        BigInt                 @id @default(autoincrement())
  content   String?
  metadata  Json?
  embedding Unsupported("vector")?
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([email, token])
  @@index([email])
  @@map("password_reset_tokens")
}
